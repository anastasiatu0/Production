<Window x:Class="Production.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Production"
        mc:Ignorable="d"
        Title="Вход" Height="450" Width="800" Icon="/Images/icon.ico">
    <Grid>
        <TextBox x:Name="EmailInput" HorizontalAlignment="Left" Margin="333,162,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="185" Height="33"/>
        <PasswordBox x:Name="PasswordInput" HorizontalAlignment="Left" Margin="333,217,0,0" VerticalAlignment="Top" Width="185" Height="27"/>
        <Button Content="Войди в меня" HorizontalAlignment="Left" Margin="361,276,0,0" VerticalAlignment="Top" Height="32" Width="129" Click="Button_Click"/>
        <Button x:Name="Exit" Content="Выйти из приложения" HorizontalAlignment="Left" Margin="361,313,0,0" VerticalAlignment="Top" Height="32" Width="129" Click="Exit_Click" />

    </Grid>
</Window>
